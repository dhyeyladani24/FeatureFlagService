# Server (HOST=0.0.0.0 is default — listen on all interfaces; use 127.0.0.1 to accept local only)
PORT=3000
# HOST=0.0.0.0

# PostgreSQL — required. Use either DATABASE_URL or the PG* variables below.
#
# macOS (Homebrew): often no password for local user — replace YOUR_USERNAME with `whoami`
#   DATABASE_URL=postgresql://YOUR_USERNAME@localhost:5432/feature_flags
#
# Linux / password auth example:
#   DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/feature_flags
#
DATABASE_URL=postgresql://YOUR_USERNAME@localhost:5432/feature_flags

# Alternative to DATABASE_URL:
# PGUSER=youruser
# PGPASSWORD=yourpassword
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=feature_flags

# Redis (local default)
REDIS_URL=redis://127.0.0.1:6379

# --- Rate limiting (two different numbers — do not swap) ---
# RATE_LIMIT_WINDOW_SECONDS = length of the sliding window in SECONDS (e.g. 60 = one minute).
# RATE_LIMIT_MAX_REQUESTS     = how many requests are allowed inside that window (per x-user-id or IP).
#
# Normal dev:  WINDOW_SECONDS=60  MAX_REQUESTS=100
# Demo 429:    WINDOW_SECONDS=60  MAX_REQUESTS=3   → 4th request in ~1s returns 429
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# Feature Redis cache: false / 0 / off / omit = ON. true / 1 / yes / on = OFF (Postgres only).
# Default should be false so GET /features/:env/:name uses Redis. Server loads .env with override:true (beats stray shell export SKIP_CACHE=true).
SKIP_CACHE=false

# Cache TTL for feature reads (seconds)
FEATURE_CACHE_TTL_SECONDS=300

# Log [cache] MISS / HIT / SET lines to the server terminal (set false to disable)
CACHE_LOG=true
